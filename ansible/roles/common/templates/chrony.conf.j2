# =============================================================
# chrony.conf.j2 — конфигурация NTP клиента
#
# Синхронизация времени критична для K8s:
#   - TLS-сертификаты etcd имеют срок действия
#   - Логи нод должны быть синхронизированы для отладки
#   - etcd требует синхронизированного времени для consensus
# =============================================================

# NTP серверы (из group_vars/all.yml)
{% for server in ntp_servers %}
server {{ server }} iburst
{% endfor %}

# Разрешить большие начальные поправки (при первом запуске)
makestep 1.0 3

# Файл с дрейфом частоты
driftfile /var/lib/chrony/drift

# Логировать изменения
logdir /var/log/chrony
